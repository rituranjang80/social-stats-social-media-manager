# React environment variables.
# Copy this file to `.env` and adjust for your environment before `npm start`.

# Prefer a relative API path when the UI is served behind the nginx gateway
# (Docker / K8s). That way changing APP_PORT or moving folders does not break calls.
# REACT_APP_API_URL=/api

# Bare-metal local dev (Django on :8000, React on :3000):
REACT_APP_API_URL=http://localhost:8000/api
